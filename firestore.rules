rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Mindenki csak a saját dokumentumát olvashatja/írhatja (a Google-fiókja azonosítója alatt).
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
